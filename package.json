    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.0.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.475.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
